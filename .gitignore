.env
.env.local
.env.*.local

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store

# Python / Backend
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
backend/venv/
backend/env/
*.db
*.sqlite
*.sqlite3

# Node / Frontend
frontend/node_modules/
frontend/.next/
frontend/out/
frontend/build/
frontend/.vercel/
frontend/npm-debug.log*
frontend/yarn-debug.log*
frontend/yarn-error.log*

# Docker
docker-compose.override.yml

# Repository Root Dump Files
/code_dumper.py
/full_Keshepool_project_code.txt
code_dumper.py
full_Keshepool_project_code.txt

#Design Png Files
Design_Refrence

# Claude AI and Graphify Ignore Rules
CLAUDE.md
graphify-out/

#backups
backups/*
!backups/.gitkeep