# /keshepool/.env

POSTGRES_USER=keshepool_user
POSTGRES_PASSWORD=change_me_to_a_strong_random_password
POSTGRES_DB=keshepool_db

BOT_TOKEN=your_main_bot_token
BOT_USERNAME=keshepoolbot
WEBHOOK_URL=https://your-domain.example
WEB_APP_URL=https://your-domain.example
TETRA98_API_URL=https://tetra98.com
TETRA98_API_KEY=
TETRA98_WEBHOOK_SECRET=
CRYPTO_DEPOSIT_ADDRESS_USDT=
CRYPTO_WEBHOOK_SECRET=
# Operator-reviewed emergency fallback used only when live rate sources fail.
USDT_TO_IRR_RATE=replace_with_current_toman_rate
ALLOW_INSECURE_DEV_AUTH=false
TELEGRAM_AUTH_MAX_AGE_SECONDS=86400
TELEGRAM_AUTH_FUTURE_SKEW_SECONDS=60
USER_LAST_SEEN_WRITE_INTERVAL_SECONDS=300

ADMIN_BOT_TOKEN=your_stealth_admin_token
ADMIN_TELEGRAM_IDS=123456789,987654321
ADMIN_GROUP_CHAT_ID=-1001234567890

ASSET_ROOT=/app/static
PUBLIC_ASSET_BASE_URL=/static
SUPPORT_TELEGRAM_USERNAME=keshepool_support
CACHE_NAMESPACE=keshepool
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2

WEBHOOK_SECRET=your_long_random_secure_string_here
ADMIN_API_KEY=a_very_long_random_string
ENVIRONMENT=production

# Deployment uses one immutable commit tag for both application images.
REGISTRY_IMAGE=registry.example.com/group/keshepool
IMAGE_TAG=0000000000000000000000000000000000000000

# Timezone for backup scheduling/logs
TZ=Asia/Tehran
