# /keshepool/.env

POSTGRES_USER=keshepool_user
POSTGRES_PASSWORD=change_me_to_a_strong_random_password
POSTGRES_DB=keshepool_db

BOT_TOKEN=your_main_bot_token
WEBHOOK_URL=https://keshepool.duckdns.org
WEB_APP_URL=https://keshepool.duckdns.org
TETRA98_API_URL=https://api.tetra98.com
TETRA98_API_KEY=your_key
ALLOW_INSECURE_DEV_AUTH=false

ADMIN_BOT_TOKEN=your_stealth_admin_token
ADMIN_TELEGRAM_IDS=123456789,987654321
ADMIN_GROUP_CHAT_ID=-1001234567890

ASSET_ROOT=/app/static
PUBLIC_ASSET_BASE_URL=/static
NEXT_PUBLIC_API_URL=https://keshepool.duckdns.org/api
NEXT_PUBLIC_BOT_USERNAME=keshepoolbot

WEBHOOK_SECRET=your_long_random_secure_string_here
